# Publikus alap URL a canonical, sitemap, Open Graph és metadataBase réteghez
APP_BASE_URL=https://www.imperiogepeszet.hu

# Supabase böngészős feltöltéshez és szerveroldali admin olvasáshoz
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Belső admin belépés és szerveroldali e-mail küldés
ADMIN_ACCESS_TOKEN=
RESEND_API_KEY=
ADMIN_NOTIFICATION_EMAIL=
ADMIN_NOTIFICATION_FROM_EMAIL=

# Publikus analitika
# Ha a GTM azonosító be van állítva, a kliensoldali mérés elsődlegesen oda megy.
# Ha nincs GTM, de van GA4 mérési azonosító, akkor közvetlen GA4 küldés történik.
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
